<Window x:Class="DrivingSchool.Views.MarkPassedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отметка результатов экзамена" 
        Height="450" 
        Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Text="Отметьте, что сдал каждый студент:" 
                   FontWeight="Bold" Margin="5" FontSize="14"/>

        <DataGrid x:Name="StudentsGrid" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  Margin="5"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  AlternatingRowBackground="LightGray"
                  RowHeight="35">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Студент" 
                                    Binding="{Binding StudentName, Mode=OneWay}" 
                                    Width="200"
                                    IsReadOnly="True"/>

                <DataGridTextColumn Header="Категория" 
                                    Binding="{Binding CategoryCode, Mode=OneWay}" 
                                    Width="80"
                                    IsReadOnly="True"/>

                <!-- Чекбокс для результата (только один, в зависимости от этапа) -->
                <DataGridTemplateColumn x:Name="ResultColumn" Header="Результат" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding ExamPassed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding ExamEditable}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Попыток" 
                                    Binding="{Binding AttemptsCount, Mode=OneWay}" 
                                    Width="80"
                                    IsReadOnly="True"/>

                <DataGridTextColumn Header="Статус" 
                                    Binding="{Binding StatusDisplay, Mode=OneWay}" 
                                    Width="220"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Black"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="✅ Сдан">
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="❌ Не сдан">
                                    <Setter Property="Foreground" Value="Red"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,10,0,0">
            <Button Content="Сохранить" 
                    Click="Save_Click" 
                    Width="100" 
                    Height="35"
                    Margin="5" 
                    Padding="10,5"
                    IsDefault="True"
                    Background="LightGreen"
                    FontWeight="Bold"/>
            <Button Content="Отмена" 
                    Click="Cancel_Click" 
                    Width="100" 
                    Height="35"
                    Margin="5" 
                    Padding="10,5"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>