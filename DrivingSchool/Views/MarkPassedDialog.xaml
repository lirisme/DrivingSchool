<Window x:Class="DrivingSchool.Views.MarkPassedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отметка результатов экзамена" 
        Height="500" 
        Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Отметьте, что сдал каждый студент:" 
                   FontWeight="Bold" 
                   Margin="5"
                   FontSize="14"/>

        <DataGrid x:Name="StudentsGrid" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  Margin="5"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  AlternatingRowBackground="LightGray"
                  RowHeight="30">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Студент" 
                                    Binding="{Binding StudentName, Mode=OneWay}" 
                                    Width="200"
                                    IsReadOnly="True"/>

                <DataGridTextColumn Header="Категория" 
                                    Binding="{Binding CategoryCode, Mode=OneWay}" 
                                    Width="80"
                                    IsReadOnly="True"/>

                <!-- Чекбокс для теории -->
                <DataGridTemplateColumn Header="Теория" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding TheoryPassed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding TheoryEditable}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Чекбокс для практики -->
                <DataGridTemplateColumn Header="Практика" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding PracticePassed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding PracticeEditable}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Попыток" 
                                    Binding="{Binding AttemptsCount, Mode=OneWay}" 
                                    Width="80"
                                    IsReadOnly="True"/>

                <DataGridTextColumn Header="Статус" 
                                    Binding="{Binding StatusDisplay, Mode=OneWay}" 
                                    Width="180"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Black"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Ожидает сдачи">
                                    <Setter Property="Foreground" Value="Orange"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="✅ Уже сданы оба этапа">
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="✅ Теория сдана, нужно сдать практику">
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="✅ Практика сдана, нужно сдать теорию">
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="❌ Нет допуска (не сдана внутренняя теория)">
                                    <Setter Property="Foreground" Value="Red"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="❌ Нет допуска (не сдана внутренняя практика)">
                                    <Setter Property="Foreground" Value="Red"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="⚠️ Превышены попытки теории (3/3)">
                                    <Setter Property="Foreground" Value="Red"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="⚠️ Превышены попытки практики (3/3)">
                                    <Setter Property="Foreground" Value="Red"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,10,0,0">
            <Button Content="Сохранить" 
                    Click="Save_Click" 
                    Width="100" 
                    Height="35"
                    Margin="5" 
                    Padding="10,5"
                    IsDefault="True">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="LightGreen"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Отмена" 
                    Click="Cancel_Click" 
                    Width="100" 
                    Height="35"
                    Margin="5" 
                    Padding="10,5"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>