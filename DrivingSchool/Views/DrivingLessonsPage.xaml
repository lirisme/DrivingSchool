<Page x:Class="DrivingSchool.Views.DrivingLessonsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Календарь бронирования"
      Background="White">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Календарь бронирования уроков вождения" 
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Панель управления -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,10" HorizontalAlignment="Left">

            <!-- Выбор студента -->
            <Border Background="#F0F8FF" CornerRadius="5" Padding="10" Margin="0,0,10,0" Width="280">
                <StackPanel>
                    <TextBlock Text="Студент:" FontWeight="Bold"/>
                    <TextBox x:Name="StudentSearchBox" Width="220" 
                             TextChanged="StudentSearchBox_TextChanged"/>
                    <ListBox x:Name="StudentResultsList" Height="120" 
                             SelectionChanged="StudentResultsList_SelectionChanged"
                             DisplayMemberPath="FullName"
                             Visibility="Collapsed"
                             Background="White"/>

                    <Border x:Name="SelectedStudentPanel" 
                            Background="#E8F4FD" 
                            CornerRadius="5" 
                            Padding="8" 
                            Margin="0,10,0,0"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Выбран:" FontWeight="Bold"/>
                            <TextBlock x:Name="SelectedStudentName" FontWeight="Bold"/>
                            <TextBlock x:Name="StudentDetails" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                            <Button Content="✕ Сменить" 
                                    Click="ClearStudent_Click"
                                    Width="80" Height="25"
                                    Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Выбор инструктора -->
            <Border Background="#F0F8FF" CornerRadius="5" Padding="10" Margin="0,0,10,0" Width="280">
                <StackPanel>
                    <TextBlock Text="Инструктор:" FontWeight="Bold"/>
                    <TextBox x:Name="InstructorSearchBox" Width="220" 
                             TextChanged="InstructorSearchBox_TextChanged"/>
                    <ListBox x:Name="InstructorResultsList" Height="120" 
                             SelectionChanged="InstructorResultsList_SelectionChanged"
                             DisplayMemberPath="DisplayName"
                             Visibility="Collapsed"
                             Background="White"/>

                    <Border x:Name="SelectedInstructorPanel" 
                            Background="#E8F4FD" 
                            CornerRadius="5" 
                            Padding="8" 
                            Margin="0,10,0,0"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Выбран инструктор:" FontWeight="Bold"/>
                            <TextBlock x:Name="SelectedInstructorName" FontWeight="Bold"/>
                            <TextBlock x:Name="InstructorDetails" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                            <Button Content="✕ Сбросить" 
                                    Click="ClearInstructor_Click"
                                    Width="80" Height="25"
                                    Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Навигация по месяцам -->
            <Border Background="#F0F8FF" CornerRadius="5" Padding="10" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Месяц:" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="◀" Click="PrevMonth_Click" Width="30" Margin="0,0,5,0"/>
                        <TextBlock x:Name="MonthYearText" FontSize="14" FontWeight="Bold" 
                                   VerticalAlignment="Center" Width="150" TextAlignment="Center"/>
                        <Button Content="▶" Click="NextMonth_Click" Width="30" Margin="5,0,0,0"/>
                    </StackPanel>
                    <Button Content="Сегодня" Click="Today_Click" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Информация -->
            <Border Background="#F0F8FF" CornerRadius="5" Padding="10" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Информация:" FontWeight="Bold"/>
                    <TextBlock x:Name="LessonsStatsText" FontSize="11" FontWeight="Bold" 
                               TextAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                    <Button Content="✏️ Ручное бронирование" 
                            Click="ManualBooking_Click"
                            Margin="0,5,0,0"
                            Padding="5"/>
                </StackPanel>
            </Border>

            <!-- Управление слотами -->
            <Border Background="#F0F8FF" CornerRadius="5" Padding="10" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Временные слоты:" FontWeight="Bold"/>
                    <Button Content="⚙️ Управление слотами" 
                            Click="ManageTimeSlots_Click"
                            Margin="0,5,0,0"
                            Padding="5"
                            Background="#E8F4FD"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Календарная сетка с фиксированной временной шкалой И ЛИСТОМ ОЖИДАНИЯ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Фиксированная временная шкала -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="TimeSlotsPanel">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Height="80" BorderBrush="#DDD" BorderThickness="0,0,1,0" 
                                        Background="#F5F5F5" Padding="5"
                                        MouseLeftButtonDown="TimeSlot_DoubleClick"
                                        Tag="{Binding}">
                                    <TextBlock Text="{Binding}" FontWeight="Bold" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Прокручиваемый календарь -->
            <ScrollViewer x:Name="MainScrollViewer" Grid.Column="1" 
                          HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Auto"
                          Loaded="ScrollViewer_Loaded">
                <ItemsControl x:Name="CalendarGrid">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="5">
                                <ItemsControl ItemsSource="{Binding Days}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="100" Height="80" 
                                                    Background="{Binding Background}"
                                                    BorderBrush="LightGray" 
                                                    BorderThickness="1"
                                                    Margin="2" CornerRadius="3"
                                                    MouseLeftButtonUp="Slot_Click"
                                                    MouseRightButtonUp="Slot_RightClick"
                                                    Tag="{Binding SlotId}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                <Setter Property="BorderBrush" Value="Gold"/>
                                                                <Setter Property="BorderThickness" Value="3"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="📅 Забронировать" Click="BookLesson_Click"
                                                                  IsEnabled="{Binding CanBook}"/>
                                                        <MenuItem Header="❌ Отменить бронь" Click="CancelBooking_Click"
                                                                  IsEnabled="{Binding HasActiveBooking}"/>
                                                        <MenuItem Header="✅ Отметить как проведенный" Click="MarkAsCompleted_Click"/>
                                                        <MenuItem Header="⚠️ Отметить как прогул" Click="MarkAsNoShow_Click"/>
                                                        <Separator/>
                                                        <MenuItem Header="✏️ Ручное бронирование" Click="ManualBookingForSlot_Click"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding Date}" FontSize="12" HorizontalAlignment="Center"/>

                                                    <!-- Имя студента (для инструктора) -->
                                                    <TextBlock Text="{Binding StudentName}" FontSize="9" 
                                                               HorizontalAlignment="Center" FontWeight="Bold"
                                                               Margin="0,2,0,0" TextWrapping="Wrap" TextAlignment="Center"/>

                                                    <!-- Статус записи на экзамен (только если записан) -->
                                                    <TextBlock Text="{Binding ExamSignText}" FontSize="8" 
                                                               Foreground="Green"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,2,0,0"/>

                                                    <TextBlock Text="{Binding Status}" FontSize="9" 
                                                               HorizontalAlignment="Center"
                                                               Foreground="{Binding StatusColor}"
                                                               Margin="0,3,0,0"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ЛИСТ ОЖИДАНИЯ / ЗАМЕТКИ (справа) -->
            <Border Grid.Column="2" Background="#FFF8E1" CornerRadius="5" Margin="10,0,0,0">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <TextBlock Grid.Row="0" Text="📋 Лист ожидания" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>

                    <!-- Поля с подписями -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,5">
                        <TextBlock Text="ФИО:" FontSize="11" Foreground="Gray" Margin="0,0,0,2"/>
                        <TextBox x:Name="NewNameTextBox" Width="Auto" Height="30" Padding="5" Margin="0,0,0,3"/>

                        <TextBlock Text="Телефон:" FontSize="11" Foreground="Gray" Margin="0,5,0,2"/>
                        <TextBox x:Name="NewPhoneTextBox" Width="Auto" Height="30" Padding="5" Margin="0,0,0,3"/>

                        <TextBlock Text="Примечания:" FontSize="11" Foreground="Gray" Margin="0,5,0,2"/>
                        <TextBox x:Name="NewNotesTextBox" Width="Auto" Height="60" Padding="5" Margin="0,0,0,3" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <Button x:Name="AddNoteButton" Content="➕ Добавить" Click="AddNote_Click" 
                    Background="#4CAF50" Foreground="White" Height="30" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Разделитель -->
                    <Border Grid.Row="2" Height="1" Background="#CCCCCC" Margin="0,5"/>

                    <!-- Список заметок (прокручиваемый) -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,5">
                        <ItemsControl x:Name="NotesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFFFFF" CornerRadius="3" Margin="0,0,0,3" Padding="5">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Phone}" FontSize="11" Foreground="Gray" Margin="0,0,0,3"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Notes}" FontSize="11" TextWrapping="Wrap"/>

                                            <Button Grid.Row="0" Grid.Column="1" Content="✕" Width="25" Height="25" 
                                        Background="#f44336" Foreground="White" FontWeight="Bold"
                                        Click="DeleteNote_Click" Tag="{Binding Id}"
                                        VerticalAlignment="Top"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Кнопка очистить все -->
                    <Button x:Name="ClearAllButton" Grid.Row="5" Content="🗑️ Очистить все" Click="ClearAllNotes_Click"
                Background="#f44336" Foreground="White" Height="30" Margin="0,5,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Легенда -->
        <Border Grid.Row="4" Background="#F0F8FF" Padding="10" CornerRadius="5" Margin="0,10,0,0">
            <WrapPanel HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Rectangle Fill="LightGreen" Width="20" Height="20" Margin="0,0,5,0"/>
                    <TextBlock Text="Свободно" Margin="0,0,15,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Rectangle Fill="LightCoral" Width="20" Height="20" Margin="0,0,5,0"/>
                    <TextBlock Text="Занято" Margin="0,0,15,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Rectangle Fill="Orange" Width="20" Height="20" Margin="0,0,5,0"/>
                    <TextBlock Text="Забронировано" Margin="0,0,15,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Rectangle Fill="Green" Width="20" Height="20" Margin="0,0,5,0"/>
                    <TextBlock Text="Проведен" Margin="0,0,15,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Rectangle Fill="Red" Width="20" Height="20" Margin="0,0,5,0"/>
                    <TextBlock Text="Прогул" Margin="0,0,15,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <Rectangle Fill="LightGray" Width="20" Height="20" Margin="0,0,5,0"/>
                    <TextBlock Text="Нет слота" Margin="0,0,15,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Rectangle Fill="LightYellow" Width="20" Height="20" Margin="0,0,5,0" Stroke="Gold" StrokeThickness="1"/>
                    <TextBlock Text="Сегодня" Margin="0,0,15,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                    <TextBlock Text="💡" FontSize="14" Margin="0,0,5,0"/>
                    <TextBlock Text="ПКМ - действия" FontSize="11" Foreground="Gray"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                    <TextBlock Text="📋" FontSize="14" Margin="0,0,5,0"/>
                    <TextBlock Text="Лист ожидания справа" FontSize="11" Foreground="Gray"/>
                </StackPanel>
            </WrapPanel>
        </Border>
    </Grid>
</Page>