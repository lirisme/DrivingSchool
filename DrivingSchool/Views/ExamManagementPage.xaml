<Page x:Class="DrivingSchool.Views.ExamManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление экзаменами" Background="#F5F5F5">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Grid.Row="0" Background="White" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CreateExamBtn" Content="➕ Создать экзамен" 
                        Padding="15,8" Background="#3498DB" Foreground="White"
                        Click="CreateExamBtn_Click" Margin="5"/>
                <Button x:Name="RefreshBtn" Content="🔄 Обновить" 
                        Padding="15,8" Click="RefreshBtn_Click" Margin="5"/>
            </StackPanel>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="1">

            <!-- Вкладка 1: Расписание экзаменов -->
            <TabItem Header="📅 Расписание экзаменов">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Строка поиска учеников -->
                    <Border Grid.Row="0" Background="#F0F0F0" Padding="5" CornerRadius="5" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍 Поиск учеников:" VerticalAlignment="Center" Margin="5,0"/>
                            <TextBox x:Name="SearchTextBox" Width="300" 
                                     TextChanged="SearchTextBox_TextChanged"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="(поиск по фамилии, имени, телефону)" 
                                       Foreground="Gray" FontSize="10" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Расписание экзаменов с прокруткой -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,10">
                        <Border Background="White" Padding="10" CornerRadius="5">
                            <StackPanel>
                                <TextBlock Text="📅 Расписание экзаменов" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                <DataGrid x:Name="SchedulesGrid" AutoGenerateColumns="False" 
                                          CanUserAddRows="False" IsReadOnly="True"
                                          MouseDoubleClick="SchedulesGrid_MouseDoubleClick">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="🗑️ Удалить экзамен" Click="DeleteExam_Click"/>
                                            <MenuItem Header="✅ Провести экзамен" Click="ConductExam_Click"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Дата" Binding="{Binding ExamDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                                        <DataGridTextColumn Header="Время" Binding="{Binding StartTime}" Width="80"/>
                                        <DataGridTextColumn Header="Тип" Binding="{Binding TypeName}" Width="100"/>
                                        <DataGridTextColumn Header="Этап" Binding="{Binding StageName}" Width="80"/>
                                        <DataGridTextColumn Header="Место" Binding="{Binding Location}" Width="200"/>
                                        <DataGridTextColumn Header="Записано" Binding="{Binding CurrentStudents}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <!-- Статус активных экзаменов -->
                    <TextBlock Grid.Row="2" x:Name="ActiveStatusText" Foreground="Gray" FontSize="11" Margin="0,5,0,5"/>

                    <!-- Список учеников с прокруткой -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Border Background="White" Padding="10" CornerRadius="5">
                            <StackPanel>
                                <TextBlock Text="👥 Ученики" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                <DataGrid x:Name="StudentsGrid" AutoGenerateColumns="False" 
                                          CanUserAddRows="False" IsReadOnly="True"
                                          SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Ученик" Binding="{Binding StudentName}" Width="200"/>
                                        <DataGridTextColumn Header="Категория" Binding="{Binding CategoryCode}" Width="80"/>
                                        <DataGridTextColumn Header="Уроков" Binding="{Binding CompletedLessons}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="{Binding LessonsColor}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Всего" Binding="{Binding TotalLessons}" Width="60"/>
                                        <DataGridTextColumn Header="Статус" Binding="{Binding OverallStatus}" Width="150"/>
                                        <DataGridTemplateColumn Header="Запись" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="📝 Записать" Tag="{Binding}" 
                                                            Click="RegisterStudentBtn_Click" 
                                                            Background="#27AE60" Foreground="White"
                                                            Padding="5,3" FontSize="11"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Вкладка 2: Проведенные экзамены -->
            <TabItem Header="✅ Проведенные экзамены">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Фильтры по типу -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Фильтр по типу:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox x:Name="PastExamTypeFilter" Width="120" SelectionChanged="PastExamTypeFilter_SelectionChanged">
                            <ComboBoxItem Content="Все экзамены" IsSelected="True"/>
                            <ComboBoxItem Content="Внутренние"/>
                            <ComboBoxItem Content="ГИБДД"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Список проведенных экзаменов с прокруткой -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,10">
                        <Border Background="White" Padding="10" CornerRadius="5">
                            <StackPanel>
                                <TextBlock Text="📋 Проведенные экзамены" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                <DataGrid x:Name="PastSchedulesGrid" AutoGenerateColumns="False" 
                                          CanUserAddRows="False" IsReadOnly="True"
                                          MouseDoubleClick="PastSchedulesGrid_MouseDoubleClick">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="🗑️ Удалить экзамен" Click="DeletePastExam_Click"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Дата" Binding="{Binding ExamDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                                        <DataGridTextColumn Header="Время" Binding="{Binding StartTime}" Width="80"/>
                                        <DataGridTextColumn Header="Тип" Binding="{Binding TypeName}" Width="100"/>
                                        <DataGridTextColumn Header="Этап" Binding="{Binding StageName}" Width="80"/>
                                        <DataGridTextColumn Header="Место" Binding="{Binding Location}" Width="200"/>
                                        <DataGridTextColumn Header="Записано" Binding="{Binding CurrentStudents}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <TextBlock Grid.Row="2" x:Name="PastStatusText" Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>