<Page x:Class="DrivingSchool.Views.FinancialReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Финансовые отчеты">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="💰 Финансовые отчеты" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Период -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" CornerRadius="5" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <DatePicker x:Name="StartDatePicker" Width="120" Margin="0,0,10,0"/>
                <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker x:Name="EndDatePicker" Width="120" Margin="0,0,20,0"/>
                <Button x:Name="GenerateButton" Content="Сформировать" Width="120" Click="GenerateReportButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Сводка -->
        <Border Grid.Row="2" Background="#E8F0FE" Padding="10" CornerRadius="5" Margin="0,0,0,15">
            <WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="💰 Доход:" FontWeight="Bold" Margin="0,0,5,0"/>
                    <TextBlock x:Name="TotalIncomeText" Foreground="Green" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="📊 Платежей:" FontWeight="Bold" Margin="0,0,5,0"/>
                    <TextBlock x:Name="TotalPaymentsText"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="📈 Средний:" FontWeight="Bold" Margin="0,0,5,0"/>
                    <TextBlock x:Name="AveragePaymentText"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠️ Общий долг:" FontWeight="Bold" Margin="0,0,5,0"/>
                    <TextBlock x:Name="TotalDebtText" Foreground="Red" FontWeight="Bold"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Кнопки экспорта -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="ExportDebtorsBtn" Content="📊 Экспорт должников" Width="150" Margin="0,0,10,0" Click="ExportDebtorsBtn_Click"/>
            <Button x:Name="ExportPaymentsBtn" Content="📊 Экспорт платежей" Width="150" Margin="0,0,10,0" Click="ExportPaymentsBtn_Click"/>
            <Button x:Name="ExportMonthlyBtn" Content="📊 Экспорт по месяцам" Width="150" Click="ExportMonthlyBtn_Click"/>
        </StackPanel>

        <!-- Вкладки -->
        <TabControl Grid.Row="4">
            <TabItem Header="📋 Список должников">
                <DataGrid x:Name="DebtorsGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Студент" Binding="{Binding StudentName}" Width="*"/>
                        <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}" Width="150"/>
                        <DataGridTextColumn Header="Сумма долга" Binding="{Binding DebtFormatted}" Width="120"/>
                        <DataGridTextColumn Header="Последний платеж" Binding="{Binding LastPaymentFormatted}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="💰 Детали платежей">
                <DataGrid x:Name="PaymentsGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding PaymentDateString}" Width="100"/>
                        <DataGridTextColumn Header="Студент" Binding="{Binding StudentName}" Width="*"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding AmountFormatted}" Width="120"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding PaymentType}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="📅 Разбивка по месяцам">
                <DataGrid x:Name="MonthlyBreakdownGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Месяц" Binding="{Binding MonthName}" Width="*"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding AmountFormatted}" Width="150"/>
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Count}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="📊 Отчет по группам">
                <DataGrid x:Name="GroupsGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}" Width="*"/>
                        <DataGridTextColumn Header="Студентов" Binding="{Binding StudentCount}" Width="100"/>
                        <DataGridTextColumn Header="Ожидаемый доход" Binding="{Binding ExpectedIncomeFormatted}" Width="150"/>
                        <DataGridTextColumn Header="Фактический доход" Binding="{Binding ActualIncomeFormatted}" Width="150"/>
                        <DataGridTextColumn Header="Долг" Binding="{Binding DebtFormatted}" Width="120"/>
                        <DataGridTextColumn Header="Выполнение" Binding="{Binding CompletionRateFormatted}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>