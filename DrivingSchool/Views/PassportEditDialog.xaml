<Window x:Class="DrivingSchool.Views.PassportEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование документа" 
        Height="600" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Студент -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Студент:" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="StudentNameTextBox" Grid.Row="1" Grid.Column="1" 
                 IsReadOnly="True" Background="#F0F0F0"
                 Margin="0,5" Padding="5"/>

        <!-- Тип документа -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Тип документа:*" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="DocumentTypeComboBox" Grid.Row="2" Grid.Column="1" 
                  SelectedValue="{Binding DocumentType}"
                  SelectedValuePath="Content"
                  SelectionChanged="DocumentType_SelectionChanged"
                  Margin="0,5" Padding="5" Height="30">
            <ComboBoxItem Content="Паспорт РФ" IsSelected="True"/>
            <ComboBoxItem Content="Свидетельство о рождении"/>
            <ComboBoxItem Content="Загранпаспорт"/>
            <ComboBoxItem Content="Временное удостоверение"/>
            <ComboBoxItem Content="Военный билет"/>
        </ComboBox>

        <!-- Серия (видимость зависит от типа документа) -->
        <StackPanel x:Name="SeriesPanel" Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Серия:" VerticalAlignment="Center" Width="130" Margin="0,5"/>
            <TextBox x:Name="SeriesTextBox" 
                     Text="{Binding Series, UpdateSourceTrigger=PropertyChanged}"
                     TextChanged="SeriesTextBox_TextChanged"
                     PreviewTextInput="SeriesTextBox_PreviewTextInput"
                     PreviewKeyDown="SeriesTextBox_PreviewKeyDown"
                     GotFocus="SeriesTextBox_GotFocus"
                     LostFocus="SeriesTextBox_LostFocus"
                     MaxLength="10" Width="200" Padding="5"/>
            <TextBlock x:Name="SeriesFormatHint" Text="(4 цифры)" 
                       VerticalAlignment="Center" Margin="10,0,0,0" 
                       FontSize="11" Foreground="Gray" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Номер -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Номер:*" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="NumberTextBox" Grid.Row="4" Grid.Column="1" 
                 Text="{Binding Number, UpdateSourceTrigger=PropertyChanged}"
                 PreviewTextInput="NumberTextBox_PreviewTextInput"
                 LostFocus="NumberTextBox_LostFocus"
                 MaxLength="20" Padding="5"/>

        <!-- Кем выдан -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Кем выдан:*" VerticalAlignment="Top" Margin="0,5"/>
        <TextBox x:Name="IssuedByTextBox" Grid.Row="5" Grid.Column="1" 
         Text="{Binding IssuedBy, UpdateSourceTrigger=PropertyChanged}" 
         TextChanged="IssuedByTextBox_TextChanged"
         MaxLength="200" Padding="5" TextWrapping="Wrap" AcceptsReturn="True" Height="60"/>

        <!-- Код подразделения (только для паспорта РФ) -->
        <StackPanel x:Name="DivisionCodePanel" Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Код подразделения:" VerticalAlignment="Center" Width="130" Margin="0,5"/>
            <TextBox x:Name="DivisionCodeTextBox" 
                     Text="{Binding DivisionCode, UpdateSourceTrigger=PropertyChanged}"
                     PreviewTextInput="DivisionCodeTextBox_PreviewTextInput"
                     TextChanged="DivisionCodeTextBox_TextChanged"
                     LostFocus="DivisionCodeTextBox_LostFocus"
                     MaxLength="10" Width="120" Padding="5"/>
            <TextBlock x:Name="DivisionCodeHint" Text="(123-456)" 
                       VerticalAlignment="Center" Margin="10,0,0,0" 
                       FontSize="11" Foreground="Gray"/>
        </StackPanel>

        <!-- Дата выдачи -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Дата выдачи:*" VerticalAlignment="Center" Margin="0,5"/>
        <DatePicker x:Name="IssueDatePicker" Grid.Row="7" Grid.Column="1" 
                    SelectedDate="{Binding IssueDate}"
                    Margin="0,5" Padding="5" Height="30"/>

        <!-- Информационный блок -->
        <Border Grid.Row="8" Grid.ColumnSpan="2" Background="#FFF8E1" Padding="10" CornerRadius="5" Margin="0,10">
            <TextBlock x:Name="InfoTextBlock" 
                       Text="Для паспорта РФ дата выдачи автоматически рассчитывается по возрасту студента"
                       Foreground="#E65100" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- Предупреждение -->
        <Border x:Name="WarningBorder" Grid.Row="9" Grid.ColumnSpan="2" Background="#FFEBEE" Padding="8" CornerRadius="5" Margin="0,0,0,10" Visibility="Collapsed">
            <TextBlock x:Name="WarningTextBlock" 
                       Text="" 
                       Foreground="#C62828" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="11" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Click="SaveButton_Click" 
                    Width="100" Height="35" 
                    Background="#4CAF50" Foreground="White"
                    Margin="0,0,10,0"/>
            <Button Content="Отмена" 
                    Click="CancelButton_Click" 
                    Width="100" Height="35" 
                    Background="#f44336" Foreground="White"/>
        </StackPanel>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="* - обязательные поля" 
                   Foreground="Gray" FontSize="11" HorizontalAlignment="Right" Margin="0,0,0,20"/>
    </Grid>
</Window>