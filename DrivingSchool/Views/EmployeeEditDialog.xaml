<Window x:Class="DrivingSchool.Views.EmployeeEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Редактирование сотрудника" 
        Height="550" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <!-- Список должностей -->
        <x:Array x:Key="PositionList" Type="{x:Type sys:String}">
            <sys:String>Директор</sys:String>
            <sys:String>Инструктор по вождению</sys:String>
            <sys:String>Преподаватель ПДД</sys:String>
            <sys:String>Администратор</sys:String>
            <sys:String>Бухгалтер</sys:String>
            <sys:String>Механик</sys:String>
            <sys:String>Охранник</sys:String>
            <sys:String>Уборщик</sys:String>
            <sys:String>Диспетчер</sys:String>
            <sys:String>Начальник автоколонны</sys:String>
        </x:Array>

        <!-- Список статусов -->
        <x:Array x:Key="StatusList" Type="{x:Type sys:String}">
            <sys:String>Активен</sys:String>
            <sys:String>Уволен</sys:String>
            <sys:String>В отпуске</sys:String>
            <sys:String>На больничном</sys:String>
        </x:Array>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Фамилия -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Фамилия:*" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="LastNameTextBox" Grid.Row="1" Grid.Column="1" 
                 Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Padding="5" MaxLength="50"/>

        <!-- Имя -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Имя:*" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="FirstNameTextBox" Grid.Row="2" Grid.Column="1" 
                 Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Padding="5" MaxLength="50"/>

        <!-- Отчество -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Отчество:" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="MiddleNameTextBox" Grid.Row="3" Grid.Column="1" 
                 Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Padding="5" MaxLength="50"/>

        <!-- Должность -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Должность:*" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="PositionComboBox" Grid.Row="4" Grid.Column="1" 
                  ItemsSource="{StaticResource PositionList}"
                  SelectedItem="{Binding Position}"
                  IsEditable="True"
                  Margin="0,5" Padding="5" Height="30"/>

        <!-- Статус -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Статус:" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="StatusComboBox" Grid.Row="5" Grid.Column="1" 
                  ItemsSource="{StaticResource StatusList}"
                  SelectedItem="{Binding Status}"
                  Margin="0,5" Padding="5" Height="30"/>

        <!-- Телефон -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Телефон:*" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="PhoneTextBox" Grid.Row="6" Grid.Column="1" 
                 Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                 PreviewTextInput="PhoneTextBox_PreviewTextInput"
                 PreviewKeyDown="PhoneTextBox_PreviewKeyDown"
                 DataObject.Pasting="PhoneTextBox_Pasting"
                 GotFocus="PhoneTextBox_GotFocus"
                 Margin="0,5" Padding="5"/>

        <!-- Email -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Email:" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="EmailTextBox" Grid.Row="7" Grid.Column="1" 
                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Padding="5" MaxLength="100"/>

        <!-- Дата приема -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Дата приема:*" VerticalAlignment="Center" Margin="0,5"/>
        <DatePicker x:Name="HireDatePicker" Grid.Row="8" Grid.Column="1" 
                    SelectedDate="{Binding HireDate}"
                    Margin="0,5" Padding="5" Height="30"/>

        <!-- Стаж -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="Стаж:" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="ExperienceTextBox" Grid.Row="9" Grid.Column="1" 
                 Text="{Binding Experience, Mode=OneWay}" IsReadOnly="True"
                 Margin="0,5" Padding="5" Background="#F0F0F0"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="11" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Click="SaveButton_Click" 
                    Width="100" Height="35" 
                    Background="#4CAF50" Foreground="White"
                    Margin="0,0,10,0"/>
            <Button Content="Отмена" 
                    Click="CancelButton_Click" 
                    Width="100" Height="35" 
                    Background="#f44336" Foreground="White"/>
        </StackPanel>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="* - обязательные поля" 
                   Foreground="Gray" FontSize="11" HorizontalAlignment="Right" Margin="0,0,0,20"/>
    </Grid>
</Window>