<Window x:Class="DrivingSchool.Views.CreateExamScheduleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание экзамена" Height="430" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Создание экзамена" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Тип экзамена -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Тип экзамена:" FontWeight="Bold" Margin="0,0,0,5"/>
                <RadioButton x:Name="InternalRadio" Content="Внутренний экзамен" IsChecked="True" GroupName="ExamType" Margin="0,2"/>
                <RadioButton x:Name="GIBDDRadio" Content="Экзамен в ГИБДД" GroupName="ExamType" Margin="0,2"/>
            </StackPanel>
        </Border>

        <!-- Этап экзамена (оставлено) -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Этап экзамена:" FontWeight="Bold" Margin="0,0,0,5"/>
                <RadioButton x:Name="TheoryRadio" Content="Теория (ПДД)" IsChecked="True" GroupName="ExamStage" Margin="0,2"/>
                <RadioButton x:Name="PracticeRadio" Content="Практика (вождение)" GroupName="ExamStage" Margin="0,2"/>
            </StackPanel>
        </Border>

        <!-- Дата -->
        <Grid Grid.Row="3" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Дата:" VerticalAlignment="Center"/>
            <DatePicker x:Name="ExamDatePicker" Grid.Column="1" SelectedDate="{Binding ExamDate}"/>
        </Grid>

        <!-- Место проведения -->
        <Grid Grid.Row="4" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Создать" Width="80" Padding="10,5" Background="#27AE60" Foreground="White" Click="CreateBtn_Click" Margin="5"/>
            <Button Content="Отмена" Width="80" Padding="10,5" Click="CancelBtn_Click" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>