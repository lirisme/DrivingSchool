<Window x:Class="DrivingSchool.Views.CreateExamScheduleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание экзамена" Height="434" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Создание экзамена" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Тип -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Тип:" FontWeight="Bold" Margin="0,0,0,5"/>
                <RadioButton x:Name="InternalRadio" Content="Внутренний" IsChecked="True" GroupName="ExamType" Margin="0,2"/>
                <RadioButton x:Name="GIBDDRadio" Content="ГИБДД" GroupName="ExamType" Margin="0,2"/>
            </StackPanel>
        </Border>

        <!-- Этап -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Этап:" FontWeight="Bold" Margin="0,0,0,5"/>
                <RadioButton x:Name="TheoryRadio" Content="Теория" IsChecked="True" GroupName="ExamStage" Margin="0,2"/>
                <RadioButton x:Name="PracticeRadio" Content="Практика" GroupName="ExamStage" Margin="0,2"/>
            </StackPanel>
        </Border>

        <!-- Дата -->
        <Grid Grid.Row="3" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Дата:" VerticalAlignment="Center"/>
            <DatePicker x:Name="ExamDatePicker" Grid.Column="1" Margin="5"/>
        </Grid>

        <!-- Время -->
        <Grid Grid.Row="4" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Время:" VerticalAlignment="Center"/>
            <TextBox x:Name="StartTimeTextBox" Grid.Column="1" Text="10:00" Width="60" HorizontalAlignment="Left"/>
            <TextBlock Grid.Column="2" Text="-" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBox x:Name="EndTimeTextBox" Grid.Column="3" Text="12:00" Width="60" HorizontalAlignment="Left"/>
        </Grid>

        <!-- Место -->
        <Grid Grid.Row="5" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Место:" VerticalAlignment="Center"/>
            <TextBox x:Name="LocationTextBox" Grid.Column="1" Margin="5" Text="Аудитория 101"/>
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Создать" Width="80" Padding="10,5" Background="#27AE60" Foreground="White" Click="CreateBtn_Click" Margin="5"/>
            <Button Content="Отмена" Width="80" Padding="10,5" Click="CancelBtn_Click" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>