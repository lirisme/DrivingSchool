<Window x:Class="DrivingSchool.Views.CertificateEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование свидетельства" 
        Height="520" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Студент -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Студент:" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="StudentNameTextBox" Grid.Row="1" Grid.Column="1" 
                 IsReadOnly="True" Background="#F0F0F0"
                 Margin="0,5" Padding="5"/>

        <!-- Категория -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Категория:*" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="CategoryComboBox" Grid.Row="2" Grid.Column="1" 
                  DisplayMemberPath="DisplayText" 
                  SelectedValuePath="Id"
                  SelectedValue="{Binding VehicleCategoryId}"
                  SelectionChanged="CategoryComboBox_SelectionChanged"
                  Margin="0,5" Padding="5" Height="30"/>

        <!-- Статус экзаменов -->
        <Border Grid.Row="3" Grid.ColumnSpan="2" Background="#FFF8E1" Padding="10" CornerRadius="5" Margin="0,10">
            <StackPanel>
                <TextBlock Text="📋 Статус сдачи экзаменов:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock x:Name="ExamStatusText" Text="Проверка..." Foreground="#E65100" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Серия свидетельства -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Серия:*" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="SeriesTextBox" Grid.Row="4" Grid.Column="1" 
                 Text="{Binding CertificateSeries, UpdateSourceTrigger=PropertyChanged}"
                 GotFocus="SeriesTextBox_GotFocus"
                 LostFocus="SeriesTextBox_LostFocus"
                 MaxLength="20"
                 CharacterCasing="Upper"
                 Margin="0,5" Padding="5"/>

        <!-- Номер свидетельства -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Номер:*" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="NumberTextBox" Grid.Row="5" Grid.Column="1" 
                 Text="{Binding CertificateNumber, UpdateSourceTrigger=PropertyChanged}"
                 GotFocus="NumberTextBox_GotFocus"
                 LostFocus="NumberTextBox_LostFocus"
                 MaxLength="20"
                 CharacterCasing="Upper"
                 Margin="0,5" Padding="5"/>

        <!-- Дата выдачи -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Дата выдачи:*" VerticalAlignment="Center" Margin="0,5"/>
        <DatePicker x:Name="IssueDatePicker" Grid.Row="6" Grid.Column="1" 
                    SelectedDate="{Binding IssueDate}"
                    Margin="0,5" Padding="5" Height="30"/>

        <!-- Информация -->
        <Border Grid.Row="7" Grid.ColumnSpan="2" Background="#E8F5E9" Padding="10" CornerRadius="5" Margin="0,10">
            <TextBlock x:Name="InfoTextBlock" 
                       Text="Свидетельство об окончании выдается после успешной сдачи ВНУТРЕННИХ экзаменов (теория + практика). Действует бессрочно. Формат серии и номера соответствует бланку." 
                       Foreground="#2E7D32" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- Предупреждение -->
        <Border x:Name="WarningBorder" Grid.Row="8" Grid.ColumnSpan="2" Background="#FFEBEE" Padding="8" CornerRadius="5" Margin="0,0,0,10" Visibility="Collapsed">
            <TextBlock x:Name="WarningTextBlock" 
                       Text="" 
                       Foreground="#C62828" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Click="SaveButton_Click" 
                    Width="100" Height="35" 
                    Background="#4CAF50" Foreground="White"
                    Margin="0,0,10,0"/>
            <Button Content="Отмена" 
                    Click="CancelButton_Click" 
                    Width="100" Height="35" 
                    Background="#f44336" Foreground="White"/>
        </StackPanel>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="* - обязательные поля" 
                   Foreground="Gray" FontSize="11" HorizontalAlignment="Right" Margin="0,0,0,20"/>
    </Grid>
</Window>