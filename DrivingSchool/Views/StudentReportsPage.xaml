<Page x:Class="DrivingSchool.Views.StudentReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Отчеты по студентам">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="👥 Отчеты по студентам" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Фильтры -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" CornerRadius="5" Margin="0,0,0,15">
            <WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBox x:Name="SearchBox" Width="200" TextChanged="FilterChanged"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Группа:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                    <ComboBox x:Name="GroupFilterBox" Width="150" SelectionChanged="FilterChanged"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Пол:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                    <ComboBox x:Name="GenderFilterBox" Width="100" SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="Все"/>
                        <ComboBoxItem Content="Мужской"/>
                        <ComboBoxItem Content="Женский"/>
                    </ComboBox>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="ExportStudentsBtn" Content="📊 Экспорт студентов" Width="150" Margin="0,0,10,0" Click="ExportStudentsBtn_Click"/>
            <Button x:Name="ExportExpiringBtn" Content="📊 Экспорт просроченных" Width="150" Margin="0,0,10,0" Click="ExportExpiringBtn_Click"/>
            <Button x:Name="RefreshBtn" Content="🔄 Обновить" Width="100" Click="RefreshButton_Click"/>
        </StackPanel>

        <!-- Вкладки -->
        <TabControl Grid.Row="3">
            <TabItem Header="👥 Все студенты">
                <DataGrid x:Name="StudentsGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding StudentName}" Width="*"/>
                        <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}" Width="120"/>
                        <DataGridTextColumn Header="К оплате" Binding="{Binding TotalToPayFormatted}" Width="120"/>
                        <DataGridTextColumn Header="Оплачено" Binding="{Binding TotalPaidFormatted}" Width="120"/>
                        <DataGridTextColumn Header="Долг" Binding="{Binding DebtFormatted}" Width="100"/>
                        <DataGridTextColumn Header="Прогресс" Binding="{Binding PaymentProgress}" Width="80"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding PaymentStatus}" Width="140"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Debt}" Value="0">
                                    <Setter Property="Background" Value="#DFFFD6"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Debt}" Value="1">
                                    <Setter Property="Background" Value="#FFD6D6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </TabItem>

            <TabItem Header="📊 Демография">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F0F0F0" Padding="10" Margin="5" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="📊 Общая статистика" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Всего студентов:" Width="120"/>
                                <TextBlock x:Name="TotalStudentsText" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Мужчины:" Width="120"/>
                                <TextBlock x:Name="MaleCountText" FontWeight="Bold" Foreground="Blue"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Женщины:" Width="120"/>
                                <TextBlock x:Name="FemaleCountText" FontWeight="Bold" Foreground="HotPink"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Средний возраст:" Width="120"/>
                                <TextBlock x:Name="AverageAgeText" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#F0F0F0" Padding="10" Margin="5" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="📈 Возрастное распределение" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                            <DataGrid x:Name="AgeDistributionGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="150">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Возрастная группа" Binding="{Binding AgeGroup}" Width="*"/>
                                    <DataGridTextColumn Header="Количество" Binding="{Binding Count}" Width="100"/>
                                    <DataGridTextColumn Header="Процент" Binding="{Binding Percent}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="📋 Документы">
                <DataGrid x:Name="DocumentsGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding StudentName}" Width="*"/>
                        <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}" Width="120"/>
                        <DataGridTextColumn Header="Паспорт" Binding="{Binding PassportStatus}" Width="80"/>
                        <DataGridTextColumn Header="СНИЛС" Binding="{Binding SNILSStatus}" Width="80"/>
                        <DataGridTextColumn Header="Медсправка" Binding="{Binding MedicalStatus}" Width="100"/>
                        <DataGridTextColumn Header="Адрес" Binding="{Binding AddressStatus}" Width="80"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding OverallStatus}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="⚠️ Истекающие документы">
                <DataGrid x:Name="ExpiringDocsGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО студента" Binding="{Binding StudentName}" Width="*"/>
                        <DataGridTextColumn Header="Тип документа" Binding="{Binding DocumentType}" Width="150"/>
                        <DataGridTextColumn Header="Номер" Binding="{Binding DocumentNumber}" Width="150"/>
                        <DataGridTextColumn Header="Дата истечения" Binding="{Binding ExpiryDateString}" Width="120"/>
                        <DataGridTextColumn Header="Дней осталось" Binding="{Binding DaysLeft}" Width="100"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DaysLeft}" Value="0">
                                    <Setter Property="Background" Value="#FFD6D6"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DaysLeft}" Value="1">
                                    <Setter Property="Background" Value="#FFFFD6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>