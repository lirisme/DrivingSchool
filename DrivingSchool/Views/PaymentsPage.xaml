<Page x:Class="DrivingSchool.Views.PaymentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Платежи"
      Background="White">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- 1: Панель поиска -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Результаты поиска + Выбранный студент -->
            <RowDefinition Height="Auto"/>
            <!-- 3: Информация о стоимости обучения -->
            <RowDefinition Height="Auto"/>
            <!-- 4: Прогресс бар -->
            <RowDefinition Height="Auto"/>
            <!-- 5: Панель кнопок -->
            <RowDefinition Height="*"/>
            <!-- 6: Таблица -->
            <RowDefinition Height="Auto"/>
            <!-- 7: Инфо панель -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Платежи" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Панель поиска студента -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Студент:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <TextBox x:Name="SearchTextBox" 
                     Width="300" Height="30" 
                     Padding="5" 
                     TextChanged="SearchTextBox_TextChanged"
                     ToolTip="Введите фамилию или телефон студента"/>

            <Button x:Name="ClearSearchButton" 
                    Content="✕" 
                    Width="30" Height="30" 
                    Click="ClearSearch_Click"
                    Margin="5,0,0,0"
                    ToolTip="Очистить поиск"/>

            <!-- Кнопка сброса выбора студента -->
            <Button x:Name="ClearSelectedStudentButton" 
                    Content="❌ Сбросить выбор" 
                    Width="120" Height="30" 
                    Click="ClearSelectedStudent_Click"
                    Margin="5,0,0,0"
                    Background="#FF9800" 
                    Foreground="White"
                    ToolTip="Сбросить выбранного студента"/>
        </StackPanel>

        <!-- Результаты поиска студентов и выбранный студент -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Результаты поиска -->
            <ListBox x:Name="SearchResultsListBox" 
                     Grid.Row="0"
                     MaxHeight="150"
                     Margin="130,0,0,5"
                     Visibility="Collapsed"
                     DisplayMemberPath="FullName"
                     SelectionChanged="SearchResultsListBox_SelectionChanged"
                     Background="White" BorderBrush="#CCCCCC"/>

            <!-- Выбранный студент -->
            <Border x:Name="SelectedStudentPanel" 
                    Grid.Row="1"
                    Background="#E3F2FD" 
                    Padding="10" 
                    CornerRadius="5" 
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="SelectedStudentText" FontWeight="Bold" FontSize="14"/>
                    <TextBlock x:Name="SelectedStudentDetails" FontSize="12" Foreground="#666666" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Информация о стоимости обучения -->
        <Border x:Name="TuitionPanel" Grid.Row="3" Background="#F5F5F5" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="Стоимость обучения" FontWeight="Bold" Foreground="#666"/>
                    <TextBlock x:Name="TuitionAmountText" Text="0 руб." FontSize="16" FontWeight="Bold" Foreground="#2196F3"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Скидка" FontWeight="Bold" Foreground="#666"/>
                    <TextBlock x:Name="DiscountAmountText" Text="0 руб." FontSize="16" FontWeight="Bold" Foreground="#4CAF50"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="5">
                    <TextBlock Text="Итого к оплате" FontWeight="Bold" Foreground="#666"/>
                    <TextBlock x:Name="FinalAmountText" Text="0 руб." FontSize="16" FontWeight="Bold" Foreground="#FF9800"/>
                </StackPanel>

                <Button x:Name="EditTuitionButton" 
                        Grid.Column="3"
                        Content="✏️ Изменить стоимость"
                        Click="EditTuition_Click"
                        Width="150" Height="35"
                        Background="#9C27B0" Foreground="White"
                        Margin="10,0,0,0"
                        IsEnabled="False"/>
            </Grid>
        </Border>

        <!-- Прогресс бар оплаты -->
        <Border Grid.Row="4" Background="#E8F5E8" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Статус и суммы -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock x:Name="PaidAmountText" Text="Оплачено: 0 руб." FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,20,0"/>
                    <TextBlock x:Name="RemainingAmountText" Text="Остаток: 0 руб." FontWeight="Bold" Foreground="#F44336" Margin="0,0,20,0"/>
                    <TextBlock x:Name="OverpaymentText" Text="Переплата: 0 руб." FontWeight="Bold" Foreground="#FF9800" Visibility="Collapsed"/>
                    <TextBlock x:Name="StatusText" Text="Статус: Не выбрано" FontWeight="Bold" Margin="20,0,0,0"/>
                </StackPanel>

                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ProgressText" Text="0%" FontWeight="Bold" FontSize="14" Foreground="#666"/>

                <!-- Прогресс бар -->
                <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" 
                           x:Name="PaymentProgressBar"
                           Height="25" 
                           Minimum="0" 
                           Maximum="100"
                           Value="0"
                           Foreground="#4CAF50"
                           Background="#E0E0E0"
                           BorderBrush="#CCCCCC"
                           Margin="0,5,0,0"/>
            </Grid>
        </Border>

        <!-- Панель кнопок для работы с платежами -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Right">
            <Button x:Name="AddPaymentButton" 
                    Content="➕ Добавить платеж" 
                    Click="AddPayment_Click"
                    Width="150" Height="35" 
                    Background="#4CAF50" Foreground="White"
                    Margin="0,0,10,0" IsEnabled="False"/>

            <Button x:Name="EditPaymentButton" 
                    Content="✏️ Редактировать" 
                    Click="EditPayment_Click"
                    Width="130" Height="35" 
                    Background="#2196F3" Foreground="White"
                    Margin="0,0,10,0" IsEnabled="False"/>

            <Button x:Name="DeletePaymentButton" 
                    Content="🗑️ Удалить" 
                    Click="DeletePayment_Click"
                    Width="100" Height="35" 
                    Background="#f44336" Foreground="White"
                    Margin="0,0,10,0" IsEnabled="False"/>

            <Button x:Name="ViewPaymentButton" 
                    Content="👁️ Просмотр" 
                    Click="ViewPayment_Click"
                    Width="100" Height="35" 
                    Background="#9C27B0" Foreground="White" 
                    IsEnabled="False"/>
        </StackPanel>

        <!-- Таблица с платежами -->
        <DataGrid x:Name="PaymentsGrid" 
                  Grid.Row="6"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="PaymentsGrid_SelectionChanged"
                  MouseDoubleClick="PaymentsGrid_MouseDoubleClick"
                  Margin="0,0,0,10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding PaymentDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="120"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat={}{0:N2} руб.}" Width="120"/>
                <DataGridTextColumn Header="Тип платежа" Binding="{Binding PaymentType}" Width="150"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Информация о сумме -->
        <Border Grid.Row="7" Background="#F0F8FF" Padding="10" CornerRadius="5">
            <StackPanel>
                <TextBlock x:Name="TotalAmountText" Text="Общая сумма: 0 руб." FontWeight="Bold" Foreground="#0D47A1"/>
                <TextBlock x:Name="InfoTextBlock" Text="Выберите студента для просмотра платежей" 
                          FontSize="11" Foreground="#888888" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>