<Window x:Class="DrivingSchool.Views.CarEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование транспортного средства" 
        Height="600" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Марка -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Марка:*" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="BrandTextBox" Grid.Row="1" Grid.Column="1" 
                 Text="{Binding Brand, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Padding="5" MaxLength="50"/>

        <!-- Модель -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Модель:*" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="ModelTextBox" Grid.Row="2" Grid.Column="1" 
                 Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Padding="5" MaxLength="50"/>

        <!-- Госномер -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Госномер:*" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="LicensePlateTextBox" Grid.Row="3" Grid.Column="1" 
                 Text="{Binding LicensePlate, UpdateSourceTrigger=PropertyChanged}"
                 PreviewTextInput="LicensePlateTextBox_PreviewTextInput"
                 PreviewKeyDown="LicensePlateTextBox_PreviewKeyDown"
                 DataObject.Pasting="LicensePlateTextBox_Pasting"
                 GotFocus="LicensePlateTextBox_GotFocus"
                 LostFocus="LicensePlateTextBox_LostFocus"
                 MaxLength="12"
                 Margin="0,5" Padding="5"
                 CharacterCasing="Upper"/>

        <!-- Год выпуска -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Год выпуска:*" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="YearTextBox" Grid.Row="4" Grid.Column="1" 
                 Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}"
                 PreviewTextInput="YearTextBox_PreviewTextInput"
                 MaxLength="4"
                 Margin="0,5" Padding="5"/>

        <!-- Цвет -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Цвет:" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="ColorTextBox" Grid.Row="5" Grid.Column="1" 
                 Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Padding="5" MaxLength="30"/>

        <!-- Категория ТС (из базы данных) -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Категория ТС:*" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="CategoryComboBox" Grid.Row="6" Grid.Column="1" 
                  DisplayMemberPath="DisplayText" 
                  SelectedValuePath="Code"
                  Margin="0,5" Padding="5" Height="30"/>

        <!-- VIN номер -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="VIN номер:" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="VINTextBox" Grid.Row="7" Grid.Column="1" 
                 Text="{Binding VIN, UpdateSourceTrigger=PropertyChanged}"
                 PreviewTextInput="VINTextBox_PreviewTextInput"
                 MaxLength="17"
                 Margin="0,5" Padding="5"
                 CharacterCasing="Upper"/>

        <!-- Инструктор -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Инструктор:" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="InstructorComboBox" Grid.Row="8" Grid.Column="1" 
                  DisplayMemberPath="FullName" 
                  SelectedValuePath="Id"
                  SelectedValue="{Binding InstructorId}"
                  Margin="0,5" Padding="5" Height="30"/>

        <!-- Активен -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="Статус:" VerticalAlignment="Center" Margin="0,5"/>
        <CheckBox x:Name="IsActiveCheckBox" Grid.Row="9" Grid.Column="1" 
                  IsChecked="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  Content="ТС в эксплуатации"
                  VerticalAlignment="Center"
                  Margin="0,5" Padding="5"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="11" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Click="SaveButton_Click" 
                    Width="100" Height="35" 
                    Background="#4CAF50" Foreground="White"
                    Margin="0,0,10,0"/>
            <Button Content="Отмена" 
                    Click="CancelButton_Click" 
                    Width="100" Height="35" 
                    Background="#f44336" Foreground="White"/>
        </StackPanel>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="* - обязательные поля" 
                   Foreground="Gray" FontSize="11" HorizontalAlignment="Right" Margin="0,0,0,20"/>
    </Grid>
</Window>