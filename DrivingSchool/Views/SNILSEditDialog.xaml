<Window x:Class="DrivingSchool.Views.SNILSEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование данных СНИЛС" 
        Height="480" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Студент -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Студент:" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="StudentNameTextBox" Grid.Row="1" Grid.Column="1" 
                 IsReadOnly="True" Background="#F0F0F0"
                 Margin="0,5" Padding="5"/>

        <!-- Номер СНИЛС -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Номер СНИЛС:*" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="NumberTextBox" Grid.Row="2" Grid.Column="1" 
                 Text="{Binding Number, UpdateSourceTrigger=PropertyChanged}"
                 PreviewTextInput="NumberTextBox_PreviewTextInput"
                 PreviewKeyDown="NumberTextBox_PreviewKeyDown"
                 GotFocus="NumberTextBox_GotFocus"
                 LostFocus="NumberTextBox_LostFocus"
                 Margin="0,5" Padding="5" MaxLength="14"/>

        <!-- Информация о формате -->
        <TextBlock Grid.Row="3" Grid.Column="1" 
                   Text="Формат: XXX-XXX-XXX XX (11 цифр)" 
                   Foreground="Gray" FontSize="10" Margin="5,0,0,0"/>

        <!-- Дата выдачи -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата выдачи:" VerticalAlignment="Center" Margin="0,5"/>
        <DatePicker x:Name="IssueDatePicker" Grid.Row="4" Grid.Column="1" 
                    SelectedDate="{Binding IssueDate}"
                    Margin="0,5" Padding="5" Height="30"/>

        <!-- Кем выдан -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Кем выдан:" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="IssuedByTextBox" Grid.Row="5" Grid.Column="1" 
                 Text="{Binding IssuedBy, UpdateSourceTrigger=PropertyChanged}"
                 TextChanged="IssuedByTextBox_TextChanged"
                 Margin="0,5" Padding="5" MaxLength="200"/>

        <!-- Информационный блок -->
        <Border Grid.Row="6" Grid.ColumnSpan="2" Background="#FFF8E1" Padding="10" CornerRadius="5" Margin="0,10">
            <TextBlock x:Name="InfoTextBlock" 
                       Text="СНИЛС состоит из 11 цифр: XXX-XXX-XXX XX (последние 2 цифры - контрольная сумма)"
                       Foreground="#E65100" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- Предупреждение -->
        <Border x:Name="WarningBorder" Grid.Row="7" Grid.ColumnSpan="2" Background="#FFEBEE" Padding="8" CornerRadius="5" Margin="0,0,0,10" Visibility="Collapsed">
            <TextBlock x:Name="WarningTextBlock" 
                       Text="" 
                       Foreground="#C62828" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Click="SaveButton_Click" 
                    Width="100" Height="35" 
                    Background="#4CAF50" Foreground="White"
                    Margin="0,0,10,0"/>
            <Button Content="Отмена" 
                    Click="CancelButton_Click" 
                    Width="100" Height="35" 
                    Background="#f44336" Foreground="White"/>
        </StackPanel>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="* - обязательные поля" 
                   Foreground="Gray" FontSize="11" HorizontalAlignment="Right" Margin="0,0,0,20"/>
    </Grid>
</Window>