<Window x:Class="DrivingSchool.Views.GroupEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование группы" 
        Height="480" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Номер группы -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Номер группы:*" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="NameTextBox" Grid.Row="1" Grid.Column="1" 
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="0,5" Padding="5" MaxLength="50"/>

        <!-- Категория -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Категория:*" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="CategoryComboBox" Grid.Row="2" Grid.Column="1" 
                  DisplayMemberPath="DisplayText" 
                  SelectedValuePath="Code"
                  SelectedValue="{Binding Category}"
                  Margin="0,5" Padding="5" Height="30"/>

        <!-- Статус -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Статус:" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="StatusComboBox" Grid.Row="3" Grid.Column="1" 
          SelectedValue="{Binding Status}"
          SelectedValuePath="Content"
          Margin="0,5" Padding="5" Height="30">
            <ComboBoxItem Content="Активна" IsSelected="True"/>
            <ComboBoxItem Content="Завершена"/>
            <ComboBoxItem Content="Запланирована"/>
            <ComboBoxItem Content="Отменена"/>
        </ComboBox>

        <!-- Дата начала -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата начала:*" VerticalAlignment="Center" Margin="0,5"/>
        <DatePicker x:Name="StartDatePicker" Grid.Row="4" Grid.Column="1" 
                    SelectedDate="{Binding StartDate}"
                    Margin="0,5" Padding="5" Height="30"/>

        <!-- Дата окончания -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Дата окончания:*" VerticalAlignment="Center" Margin="0,5"/>
        <DatePicker x:Name="EndDatePicker" Grid.Row="5" Grid.Column="1" 
                    SelectedDate="{Binding EndDate}"
                    Margin="0,5" Padding="5" Height="30"/>

        <!-- Длительность -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Длительность:" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox x:Name="DurationTextBox" Grid.Row="6" Grid.Column="1" 
                 Text="{Binding Duration, Mode=OneWay}" IsReadOnly="True"
                 Margin="0,5" Padding="5" Background="#F0F0F0"/>

        <!-- Информация -->
        <Border Grid.Row="7" Grid.ColumnSpan="2" Background="#FFF3E0" Padding="10" CornerRadius="5" Margin="0,10">
            <TextBlock x:Name="InfoTextBlock" 
                       Text="Длительность обучения будет рассчитана автоматически" 
                       Foreground="#E65100" FontStyle="Italic" TextWrapping="Wrap"/>
        </Border>

        <!-- Предупреждение -->
        <Border x:Name="WarningBorder" Grid.Row="8" Grid.ColumnSpan="2" Background="#FFEBEE" Padding="8" CornerRadius="5" Margin="0,0,0,10" Visibility="Collapsed">
            <TextBlock x:Name="WarningTextBlock" 
                       Text="В группе есть студенты! Категорию менять НЕЛЬЗЯ." 
                       Foreground="#C62828" FontWeight="Bold" TextWrapping="Wrap"/>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Click="SaveButton_Click" 
                    Width="100" Height="35" 
                    Background="#4CAF50" Foreground="White"
                    Margin="0,0,10,0"/>
            <Button Content="Отмена" 
                    Click="CancelButton_Click" 
                    Width="100" Height="35" 
                    Background="#f44336" Foreground="White"/>
        </StackPanel>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="* - обязательные поля" 
                   Foreground="Gray" FontSize="11" HorizontalAlignment="Right" Margin="0,0,0,20"/>
    </Grid>
</Window>