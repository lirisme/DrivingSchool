<Page x:Class="DrivingSchool.Views.DrivingLicenseDataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Водительские удостоверения"
      Background="White">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- 1: Панель поиска -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Результаты поиска + Выбранный студент (ОДНА СТРОКА) -->
            <RowDefinition Height="Auto"/>
            <!-- 3: Панель кнопок -->
            <RowDefinition Height="*"/>
            <!-- 4: Таблица -->
            <RowDefinition Height="Auto"/>
            <!-- 5: Инфо панель -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Водительские удостоверения" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Панель поиска студента -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Студент:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <TextBox x:Name="SearchTextBox" 
                     Width="300" Height="30" 
                     Padding="5" 
                     TextChanged="SearchTextBox_TextChanged"
                     ToolTip="Введите фамилию или телефон студента"/>

            <Button x:Name="ClearSearchButton" 
                    Content="✕" 
                    Width="30" Height="30" 
                    Click="ClearSearch_Click"
                    Margin="5,0,0,0"/>

            <Button x:Name="ClearSelectedStudentButton" 
                    Content="❌ Сбросить выбор" 
                    Width="120" Height="30" 
                    Click="ClearSelectedStudent_Click"
                    Margin="5,0,0,0"
                    Background="#FF9800" 
                    Foreground="White"
                    ToolTip="Сбросить выбранного студента"/>
        </StackPanel>

        <!-- Результаты поиска студентов и выбранный студент (В ОДНОЙ СТРОКЕ КАК В ПАСПОРТАХ) -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Результаты поиска -->
            <ListBox x:Name="SearchResultsListBox" 
                     Grid.Row="0"
                     MaxHeight="150"
                     Margin="130,0,0,5"
                     Visibility="Collapsed"
                     DisplayMemberPath="FullName"
                     SelectionChanged="SearchResultsListBox_SelectionChanged"
                     Background="White" BorderBrush="#CCCCCC"/>

            <!-- Выбранный студент -->
            <Border x:Name="SelectedStudentPanel" 
                    Grid.Row="1"
                    Background="#E3F2FD" 
                    Padding="10" 
                    CornerRadius="5" 
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="SelectedStudentText" FontWeight="Bold" FontSize="14"/>
                    <TextBlock x:Name="SelectedStudentDetails" FontSize="12" Foreground="#666666" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Панель кнопок - Row 3 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Right">
            <Button x:Name="AddLicenseButton" 
                    Content="➕ Добавить удостоверение" 
                    Click="AddLicense_Click"
                    Width="190" Height="35" 
                    Background="#4CAF50" Foreground="White"
                    Margin="0,0,10,0" IsEnabled="False"/>

            <Button x:Name="EditLicenseButton" 
                    Content="✏️ Редактировать" 
                    Click="EditLicense_Click"
                    Width="130" Height="35" 
                    Background="#2196F3" Foreground="White"
                    Margin="0,0,10,0" IsEnabled="False"/>

            <Button x:Name="DeleteLicenseButton" 
                    Content="🗑️ Удалить" 
                    Click="DeleteLicense_Click"
                    Width="100" Height="35" 
                    Background="#f44336" Foreground="White"
                    Margin="0,0,10,0" IsEnabled="False"/>

            <Button x:Name="ViewLicenseButton" 
                    Content="👁️ Просмотр" 
                    Click="ViewLicense_Click"
                    Width="100" Height="35" 
                    Background="#9C27B0" Foreground="White" 
                    IsEnabled="False"/>

            <Button x:Name="PrintLicenseButton" 
                    Content="🖨️ Печать" 
                    Click="PrintLicense_Click"
                    Width="100" Height="35" 
                    Background="#607D8B" Foreground="White" 
                    IsEnabled="False"/>
        </StackPanel>

        <!-- Таблица с удостоверениями - Row 4 -->
        <DataGrid x:Name="LicenseGrid" 
                  Grid.Row="4"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="LicenseGrid_SelectionChanged"
                  MouseDoubleClick="LicenseGrid_MouseDoubleClick"
                  Margin="0,0,0,10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Студент" Binding="{Binding StudentName}" Width="180"/>
                <DataGridTextColumn Header="Серия" Binding="{Binding Series}" Width="80"/>
                <DataGridTextColumn Header="Номер" Binding="{Binding Number}" Width="100"/>
                <DataGridTextColumn Header="Категории" Binding="{Binding LicenseCateg}" Width="120"/>
                <DataGridTextColumn Header="Кем выдан" Binding="{Binding IssuedBy}" Width="200"/>
                <DataGridTextColumn Header="Код подразделения" Binding="{Binding DivisionCode}" Width="120"/>
                <DataGridTextColumn Header="Дата выдачи" Binding="{Binding IssueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                <DataGridTextColumn Header="Действительно до" Binding="{Binding ExpiryDate, StringFormat={}{0:dd.MM.yyyy}}" Width="110"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Стаж" Binding="{Binding ExperienceYears}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Информационная панель - Row 5 -->
        <Border Grid.Row="5" Background="#F0F8FF" Padding="10" CornerRadius="5">
            <TextBlock x:Name="InfoTextBlock" Text="Выберите студента для работы с водительскими удостоверениями" 
                      FontStyle="Italic" Foreground="#666666"/>
        </Border>
    </Grid>
</Page>