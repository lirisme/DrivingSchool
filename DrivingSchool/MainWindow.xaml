<Window x:Class="DrivingSchool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Автошкола - Элита Авто" 
        Height="600" 
        Width="900"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с меню -->
        <Menu Grid.Row="0" Background="#F0F0F0">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="Справочники" x:Name="ReferencesMenu">
                <MenuItem Header="Учащиеся" Click="Students_Click"/>
                <MenuItem Header="Сотрудники" Click="Employees_Click"/>
                <MenuItem Header="Автомобили" Click="Cars_Click"/>
                <MenuItem Header="Группы" Click="Groups_Click"/>
                <MenuItem Header="Категории ТС" Click="Categories_Click"/>
                <MenuItem Header="Тарифы" Click="Tariffs_Click"/>
            </MenuItem>

            <MenuItem Header="Документы учащихся" x:Name="DocumentsMenu">
                <MenuItem Header="Паспортные данные" Click="PassportData_Click"/>
                <MenuItem Header="СНИЛС" Click="SNILSData_Click"/>
                <MenuItem Header="Медицинские справки" Click="MedicalData_Click"/>
                <MenuItem Header="Адреса регистрации" Click="AddressData_Click"/>
                <MenuItem Header="Свидетельства об окончании" Click="CertificateData_Click"/>
                <MenuItem Header="Водительские удостоверения" Click="DrivingLicenseData_Click"/>
            </MenuItem>

            <MenuItem Header="Финансы" x:Name="FinanceMenu">
                <MenuItem Header="Платежи" Click="Payments_Click"/>
                <MenuItem Header="Финансовые отчеты" Click="FinancialReports_Click"/>
            </MenuItem>

            <MenuItem Header="Вождение" x:Name="DrivingMenu">
                <MenuItem Header="Бронирование уроков" Click="DrivingLessons_Click"/>
            </MenuItem>

            <MenuItem Header="Экзамены" x:Name="ExamMenu">
                <MenuItem Header="Проведение экзаменов" Click="OpenExamManagement_Click"/>
            </MenuItem>

            <MenuItem Header="Отчеты" x:Name="ReportsMenu">
                <MenuItem Header="Отчеты по учащимся" Click="StudentReports_Click"/>
            </MenuItem>

            <MenuItem Header="Документы" x:Name="DocsMenu">
                <MenuItem Header="Шаблоны документов" Click="Templates_Click"/>
            </MenuItem>

            <MenuItem Header="Сервис" x:Name="ServiceMenu">
                <MenuItem Header="Создать резервную копию" Click="CreateBackup_Click"/>
                <MenuItem Header="Восстановить из копии" Click="RestoreBackup_Click"/>
                <MenuItem Header="Открыть папку с бэкапами" Click="OpenBackupFolder_Click"/>
            </MenuItem>

            <MenuItem Header="Администрирование" x:Name="AdminMenu" Visibility="Collapsed">
                <MenuItem Header="Создать пользователя" Click="CreateUser_Click"/>
            </MenuItem>

            <MenuItem Header="Помощь">
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Основная область для отображения страниц -->
        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>

        <!-- Нижняя панель статуса -->
        <StatusBar Grid.Row="2" Background="#2C3E50">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готов к работе" Foreground="White" FontWeight="Bold"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="UserInfo" Text="Пользователь: Администратор" Foreground="White"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="DateTimeText" Foreground="White"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>